"    trường hợp Py_EQ: c = size1 == size2; phá vỡ;\n"
"    trường hợp Py_NE: c = size1 != size2; phá vỡ;\n"
"    trường hợp Py_GT: c = size1 > size2; phá vỡ;\n"
