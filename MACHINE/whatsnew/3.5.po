"['a', 'b', 'c', 'd', 'e', 'f', 'g']"
msgstr ""
">>> nhập trình phân tích cấu hình\n"
">>> chuyển đổi = {}\n"
">>> conv['list'] = lambda v: [e.strip() for e in v.split() if e.strip()]\n"
">>> cfg = configparser.ConfigParser(converters=conv)\n"
">>> cfg.read_string(\"\"\"\n"
"... [s]\n"
