#: ../../whatsnew/3.14.rst:332
#, fuzzy
msgid ""
"It's easy to write (or call) code to process :class:`!Template` instances. "
"For example, here's a function that renders static parts lowercase and "
":class:`~string.templatelib.Interpolation` instances uppercase:"
msgstr ""
"Thật dễ dàng để viết (hoặc gọi) mã để xử lý các phiên bản "
":class:`!Template`. Ví dụ: đây là một hàm hiển thị chữ thường của các phần "
"tĩnh và chữ hoa của các trường hợp "
":class:`~string.templatelib.Interpolation`:"

#: ../../whatsnew/3.14.rst:336
#, python-brace-format, fuzzy
msgid ""
"from string.templatelib import Interpolation\n"
"\n"
"def lower_upper(template):\n"
"    \"\"\"Render static parts lowercase and interpolations uppercase.\"\"\"\n"
"    parts = []\n"
"    for part in template:\n"
"        if isinstance(part, Interpolation):\n"
"            parts.append(str(part.value).upper())\n"
"        else:\n"
"            parts.append(part.lower())\n"
"    return ''.join(parts)\n"
"\n"
"name = 'Wenslydale'\n"
"template = t'Mister {name}'\n"
"assert lower_upper(template) == 'mister WENSLYDALE'"
msgstr ""
"từ nội suy nhập chuỗi.templatelib\n"
"\n"
"def low_upper(mẫu):\n"
"    \"\"\"Hiển thị phần tĩnh bằng chữ thường và phần nội suy viết hoa.\"\"\"\n"
"    bộ phận = []\n"
"    cho một phần trong mẫu:\n"
"        if isinstance(phần, Nội suy):\n"
"            parts.append(str(part.value).upper())\n"
"        khác:\n"
"            parts.append(part.low())\n"
"    return ''.join(phần)\n"
"\n"
"tên = 'Wenslydale'\n"
"mẫu = t'Mister {name}'\n"
"khẳng định low_upper(template) == 'mister WENSLYDALE'"

