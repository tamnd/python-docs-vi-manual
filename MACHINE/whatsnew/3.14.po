"          name='Chủ nhật')\n"
"        tg.create_task(\n"
"          play_album('TMBTE', ['DYWTYLM', 'Aqua Regia']),\n"
"          tên='TMBTE')\n"
"\n"
"nếu __name__ == '__main__':\n"
"    asyncio.run(chính())"

