">>> khi = dt.datetime(2020, 10, 31, 12, tzinfo=ZoneInfo(\"America/Los_Angeles\"))\n"
">>> in (khi nào)\n"
"2020-10-31 12:00:00-07:00\n"
">>> khi.tzname()\n"
"'PDT'\n"
"\n"
">>> thời gian # Standard\n"
">>> khi += dt.timedelta(ngày=7)\n"
">>> in (khi nào)\n"
