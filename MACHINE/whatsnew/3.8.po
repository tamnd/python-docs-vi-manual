#: ../../whatsnew/3.8.rst:2075
#, python-brace-format, fuzzy
msgid ""
"static foo_struct *\n"
"foo_new(PyObject *type) {\n"
"    foo_struct *foo = PyObject_GC_New(foo_struct, (PyTypeObject *) type);\n"
"    if (foo == NULL)\n"
"        return NULL;\n"
"#if PY_VERSION_HEX < 0x03080000\n"
