"#if PY_VERSION_HEX < 0x03080000\n"
"    // Giải pháp cho vấn đề Python 35810; không còn cần thiết trong Python 3.8\n"
"    PY_INCREF(loại)\n"
"#endif\n"
"    trả lại foo;\n"
"}"

