#: ../../reference/import.rst:575
#, fuzzy
msgid "Module reprs"
msgstr "đại diện mô-đun"

#: ../../reference/import.rst:577
#, fuzzy
msgid ""
"By default, all modules have a usable repr, however depending on the "
