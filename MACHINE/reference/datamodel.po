#: ../../reference/datamodel.rst:3920
#, fuzzy
msgid "An example of an asynchronous iterable object::"
msgstr "Một ví dụ về đối tượng lặp không đồng bộ::"

#: ../../reference/datamodel.rst:3922
#, fuzzy
msgid ""
"class Reader:\n"
"    async def readline(self):\n"
"        ...\n"
"\n"
"    def __aiter__(self):\n"
"        return self\n"
"\n"
"    async def __anext__(self):\n"
"        val = await self.readline()\n"
"        if val == b'':\n"
"            raise StopAsyncIteration\n"
"        return val"
msgstr ""
"Trình đọc lớp:\n"
"    dòng đọc không đồng bộ (tự):\n"
"        ...\n"
"\n"
"    chắc chắn __aiter__(tự):\n"
"        tự trở về\n"
"\n"
"    async def __anext__(self):\n"
"        val = đang chờ self.readline()\n"
"        nếu giá trị == b'':\n"
"            nâng cao StopAsyncIteration\n"
"        giá trị trả lại"

#: ../../reference/datamodel.rst:3937
