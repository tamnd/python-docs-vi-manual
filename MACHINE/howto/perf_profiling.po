"$ perf report -g -i perf.jit.data"
msgstr ""
"$ bản ghi hoàn hảo -F 9999 -g -k 1 --call-graph lùn -o perf.data python -Xperf_jit my_script.py\n"
"$ perf tiêm -i perf.data --jit --output perf.jit.data\n"
"$ báo cáo hoàn hảo -g -i perf.jit.data"

#: ../../howto/perf_profiling.rst:243
#, fuzzy
