"    trở lại 23\n"
"\n"
"coroutine = chính()\n"
"trung gian_result = coroutine.send(Không có)\n"
"print(f\"Coroutine đã tạm dừng và trả về giá trị trung gian: {intermediate_result}.\")\n"
"\n"
"print(f\"Tiếp tục coroutine và gửi giá trị: 42.\")\n"
"thử:\n"
"    coroutine.send(42)\n"
