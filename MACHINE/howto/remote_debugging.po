"    eval_breaker_ptr = (\n"
"        thread_state_addr +\n"
"        debug_offsets.debugger_support.eval_breaker\n"
"    )\n"
"    breaker = read_int(pid, eval_breaker_ptr)\n"
"    breaker |= (1 << 5)\n"
"    write_int(pid, eval_breaker_ptr, breaker)"
