"người nghe = QueueListener(que, handler)\n"
"root = log.getLogger()\n"
"root.addHandler(queue_handler)\n"
"formatter = log.Formatter('%(threadName)s: %(message)s')\n"
"handler.setFormatter(formatter)\n"
