#: ../../howto/logging-cookbook.rst:4146
#, python-format, fuzzy
msgid ""
"import logging\n"
"\n"
"logger = logging.getLogger(__name__)\n"
"\n"
"class EscapingFormatter(logging.Formatter):\n"
"    def format(self, record):\n"
"        s = super().format(record)\n"
"        return s.replace('\\n', r'\\n')\n"
