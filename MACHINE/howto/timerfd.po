"                    # Check nếu có yêu cầu kết nối.\n"
"                    print(f\"Đang chấp nhận kết nối {fd}\")\n"
"                    kết nối, addr = sock.accept()\n"
"                    conn.setblocking(Sai)\n"
"                    print(f\"Kết nối được chấp nhận {conn} từ {addr}\")\n"
