"ep = select.epoll()\n"
"\n"
"# In trong ví dụ này, hãy sử dụng địa chỉ loopback để gửi lệnh \"stop\" tới máy chủ.\n"
"#\n"
"#$telnet 127.0.0.1 1234\n"
