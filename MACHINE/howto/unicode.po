"\n"
"    return NFD(s1) == NFD(s2)\n"
"\n"
"single_char = 'ê'\n"
"multiple_chars = '\\N{LATIN SMALL LETTER E}\\N{COMBINING CIRCUMFLEX ACCENT}'\n"
