"\n"
"    @cached_property\n"
"    vị trí def (tự):\n"
"        \"Trả về tọa độ kinh độ/vĩ độ của trạm\"\n"
"        # Result chỉ phụ thuộc vào station_id\n"
"\n"
"    @lru_cache(maxsize=20)\n"
"    def lịch sử_rainfall(tự, ngày, đơn vị='mm'):\n"
"        \"Lượng mưa vào một ngày nhất định\"\n"
"        # Depends trên station_id, ngày và đơn vị."

