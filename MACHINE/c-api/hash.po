"Xem thêm thành viên :c:member:`PyTypeObject.tp_hash` và :ref:`numeric-hash`."

#: ../../c-api/hash.rst:10
#, fuzzy
msgid "Hash value type: signed integer."
msgstr "Loại giá trị băm: số nguyên có dấu."

#: ../../c-api/hash.rst:17
