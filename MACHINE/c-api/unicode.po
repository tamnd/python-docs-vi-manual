#: ../../c-api/unicode.rst:319
#, fuzzy
msgid "Check if *ch* is a surrogate (``0xD800 <= ch <= 0xDFFF``)."
msgstr ""
"Kiểm tra xem *ch* có phải là người thay thế (``0xD800 <= ch <= 0xDFFF``) "
