#: ../../c-api/typeobj.rst:2519
#, fuzzy
msgid ""
":c:member:`~PyTypeObject.tp_finalize` should leave the current exception "
"status unchanged.  The recommended way to write a non-trivial finalizer is "
"to back up the exception at the beginning by calling "
":c:func:`PyErr_GetRaisedException` and restore the exception at the end by "
"calling :c:func:`PyErr_SetRaisedException`.  If an exception is encountered "
"in the middle of the finalizer, log and clear it with "
":c:func:`PyErr_WriteUnraisable` or :c:func:`PyErr_FormatUnraisable`.  For "
"example::"
msgstr ""
":c:member:`~PyTypeObject.tp_finalize` nên giữ nguyên trạng thái ngoại lệ "
"hiện tại.  Cách được khuyến nghị để viết một trình hoàn thiện không tầm "
"thường là sao lưu ngoại lệ ngay từ đầu bằng cách gọi "
":c:func:`PyErr_GetRaisedException` và khôi phục ngoại lệ ở cuối bằng cách "
"gọi :c:func:`PyErr_SetRaisedException`.  Nếu gặp phải ngoại lệ ở giữa trình "
"hoàn thiện, hãy đăng nhập và xóa ngoại lệ đó bằng "
":c:func:`PyErr_WriteUnraisable` hoặc :c:func:`PyErr_FormatUnraisable`.  Ví "
"dụ::"

#: ../../c-api/typeobj.rst:2528
#, fuzzy
msgid ""
"static void\n"
"foo_finalize(PyObject *self)\n"
"{\n"
"    // Save the current exception, if any.\n"
"    PyObject *exc = PyErr_GetRaisedException();\n"
"\n"
"    // ...\n"
"\n"
"    if (do_something_that_might_raise() != success_indicator) {\n"
"        PyErr_WriteUnraisable(self);\n"
"        goto done;\n"
"    }\n"
"\n"
"done:\n"
"    // Restore the saved exception.  This silently discards any exception\n"
"    // raised above, so be sure to call PyErr_WriteUnraisable first if\n"
"    // necessary.\n"
"    PyErr_SetRaisedException(exc);\n"
"}"
msgstr ""
"khoảng trống tĩnh\n"
"foo_finalize(PyObject *self)\n"
"{\n"
"    // Lưu ngoại lệ hiện tại, nếu có.\n"
"    PyObject *exc = PyErr_GetRaisedException();\n"
"\n"
"    // ...\n"
"\n"
"    if (do_something_that_might_raise() != thành công_indicator) {\n"
"        PyErr_WriteUnraiseable(self);\n"
"        phải làm xong;\n"
"    }\n"
"\n"
"xong:\n"
"    // Khôi phục ngoại lệ đã lưu.  Điều này âm thầm loại bỏ mọi ngoại lệ\n"
"    // được nêu ở trên, vì vậy hãy nhớ gọi PyErr_WriteUnraisable trước nếu\n"
"    // cần thiết.\n"
"    PyErr_SetRaisedException(exc);\n"
"}"

