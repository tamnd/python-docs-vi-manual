"mm = mmap.mmap(-1, 13)\n"
"mm.write(b\"Xin chào thế giới!\")\n"
"\n"
"pid = os.fork()\n"
"\n"
"if pid == 0: # In một tiến trình con\n"
"    mm.seek(0)\n"
"    in(mm.readline())\n"
"\n"
"    mm.close()"

