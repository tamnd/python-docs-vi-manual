"\n"
"    def ngẫu nhiên (tự):\n"
"        lớp phủ = 0x10_0000_0000_0000 | self.getrandbits(52)\n"
"        số mũ = -53\n"
"        x = 0\n"
"        trong khi không x:\n"
"            x = self.getrandbits(32)\n"
"            số mũ += x.bit_length() - 32\n"
"        trả về ldexp(mantissa, số mũ)"

