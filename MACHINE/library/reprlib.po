#: ../../library/reprlib.rst:73
#, fuzzy
msgid ""
">>> from reprlib import recursive_repr\n"
">>> class MyList(list):\n"
"...     @recursive_repr()\n"
"...     def __repr__(self):\n"
"...         return '<' + '|'.join(map(repr, self)) + '>'\n"
"...\n"
">>> m = MyList('abc')\n"
">>> m.append(m)\n"
">>> m.append('x')\n"
">>> print(m)\n"
"<'a'|'b'|'c'|...|'x'>"
msgstr ""
">>> từ nhập reprlib recursive_repr\n"
">>> lớp MyList(danh sách):\n"
"... @recursive_repr()\n"
"... def __repr__(self):\n"
"... return '<' + '|'.join(map(repr, self)) + '>'\n"
"...\n"
">>> m = MyList('abc')\n"
">>> m.append(m)\n"
">>> m.append('x')\n"
">>> in(m)\n"
"<'a'|'b'|'c'|...|'x'>"

