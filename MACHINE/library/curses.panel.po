#: ../../library/curses.panel.rst:82
#, fuzzy
msgid ""
"Hide the panel. This does not delete the object, it just makes the window on"
" screen invisible."
msgstr ""
"Ẩn bảng điều khiển. Thao tác này không xóa đối tượng mà chỉ làm cho cửa sổ "
"trên màn hình trở nên vô hình."

#: ../../library/curses.panel.rst:88
#, fuzzy
msgid "Move the panel to the screen coordinates ``(y, x)``."
msgstr "Di chuyển bảng điều khiển ra màn hình tọa độ ``(y, x)``."

#: ../../library/curses.panel.rst:93
#, fuzzy
msgid "Change the window associated with the panel to the window *win*."
msgstr "Thay đổi cửa sổ liên kết với bảng điều khiển thành cửa sổ *win*."

#: ../../library/curses.panel.rst:98
#, fuzzy
msgid ""
"Set the panel's user pointer to *obj*. This is used to associate an "
"arbitrary piece of data with the panel, and can be any Python object."
msgstr ""
"Đặt con trỏ người dùng của bảng thành *obj*. Điều này được sử dụng để liên "
"kết một phần dữ liệu tùy ý với bảng điều khiển và có thể là bất kỳ đối tượng"
" Python nào."

#: ../../library/curses.panel.rst:104
#, fuzzy
msgid "Display the panel (which might have been hidden)."
msgstr "Hiển thị bảng điều khiển (có thể đã bị ẩn)."

#: ../../library/curses.panel.rst:109
#, fuzzy
msgid "Push panel to the top of the stack."
msgstr "Đẩy bảng điều khiển lên trên cùng của ngăn xếp."

#: ../../library/curses.panel.rst:114
