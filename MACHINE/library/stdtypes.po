#: ../../library/stdtypes.rst:6516
#, fuzzy
msgid ""
"The default :data:`sys.int_info.default_max_str_digits` is expected to be "
"reasonable for most applications. If your application requires a different "
"limit, set it from your main entry point using Python version agnostic code "
"as these APIs were added in security patch releases in versions before 3.12."
msgstr ""
":data:`sys.int_info.default_max_str_digits` mặc định được cho là hợp lý cho "
"hầu hết các ứng dụng. Nếu ứng dụng của bạn yêu cầu một giới hạn khác, hãy "
"đặt giới hạn đó từ điểm vào chính bằng cách sử dụng mã bất khả tri của phiên"
" bản Python vì các API này đã được thêm vào trong các bản phát hành bản vá "
"bảo mật ở các phiên bản trước 3.12."

#: ../../library/stdtypes.rst:6521
#, fuzzy
msgid "Example::"
msgstr "Ví dụ::"

#: ../../library/stdtypes.rst:6523
#, fuzzy
msgid ""
">>> import sys\n"
">>> if hasattr(sys, \"set_int_max_str_digits\"):\n"
"...     upper_bound = 68000\n"
"...     lower_bound = 4004\n"
"...     current_limit = sys.get_int_max_str_digits()\n"
"...     if current_limit == 0 or current_limit > upper_bound:\n"
"...         sys.set_int_max_str_digits(upper_bound)\n"
"...     elif current_limit < lower_bound:\n"
"...         sys.set_int_max_str_digits(lower_bound)"
msgstr ""
">>> nhập hệ thống\n"
">>> if hasattr(sys, \"set_int_max_str_digits\"):\n"
"... giới hạn trên = 68000\n"
"... giới hạn dưới = 4004\n"
"... current_limit = sys.get_int_max_str_digits()\n"
"... nếu current_limit == 0 hoặc current_limit > giới hạn trên:\n"
"... sys.set_int_max_str_digits(upper_bound)\n"
"... elif current_limit < low_bound:\n"
"... sys.set_int_max_str_digits(low_bound)"

