"... chắc chắn f():\n"
"... def w(): vượt qua\n"
"...\n"
"... def g(self): vượt qua\n"
"...\n"
"... @classmethod\n"
"... async def h(cls): vượt qua\n"
"...\n"
"... toàn cầu bên ngoài\n"
"... def bên ngoài (tự): vượt qua\n"
"... ''', 'kiểm tra', 'thực thi')\n"
">>> class_A = st.get_children()[2]\n"
">>> class_A.get_methods()\n"
"('f', 'g', 'h')"

