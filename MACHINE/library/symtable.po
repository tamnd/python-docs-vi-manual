"...    def f():\n"
"...        def w(): pass\n"
"...\n"
"...    def g(self): pass\n"
"...\n"
"...    @classmethod\n"
"...    async def h(cls): pass\n"
"...\n"
"...    global outer\n"
"...    def outer(self): pass\n"
"... ''', 'test', 'exec')\n"
">>> class_A = st.get_children()[2]\n"
">>> class_A.get_methods()\n"
