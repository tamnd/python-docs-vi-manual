">>> từ nhập thập phân *\n"
">>> getcontext()\n"
"Bối cảnh(prec=28, làm tròn=ROUND_HALF_EVEN, Emin=-999999, Emax=999999,\n"
"        chữ hoa=1, kẹp=0, cờ=[], bẫy=[Tràn, DivisionByZero,\n"
"        Thao tác không hợp lệ])\n"
"\n"
">>> getcontext().prec = 7 # Set độ chính xác mới"

#: ../../library/decimal.rst:141
