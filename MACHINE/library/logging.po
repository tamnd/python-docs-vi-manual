#: ../../library/logging.rst:1542
#, fuzzy
msgid ""
"This function is used to turn the capture of warnings by logging on and off."
msgstr ""
"Chức năng này được sử dụng để bật và tắt tính năng ghi lại cảnh báo bằng "
