#: ../../library/multiprocessing.shared_memory.rst:266
#, fuzzy
msgid ""
">>> with SharedMemoryManager() as smm:\n"
"...     sl = smm.ShareableList(range(2000))\n"
"...     # Divide the work among two processes, storing partial results in sl\n"
