"nhập khẩu tracemalloc\n"
"\n"
"tracemalloc.start()\n"
"\n"
"# ... chạy ứng dụng của bạn ...\n"
"\n"
"ảnh chụp nhanh = tracemalloc.take_snapshot()\n"
"top_stats = snapshot.statistics('lineno')\n"
"\n"
"print(\"[Top 10]\")\n"
"cho chỉ số trong top_stats[:10]:\n"
"    in (thống kê)"

