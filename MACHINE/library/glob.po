":func:`glob` sẽ cho ra kết quả như sau.  Lưu ý cách giữ nguyên mọi thành "
"phần hàng đầu của đường dẫn. ::"

#: ../../library/glob.rst:187
#, fuzzy
msgid ""
">>> import glob\n"
">>> glob.glob('./[0-9].*')\n"
"['./1.gif', './2.txt']\n"
">>> glob.glob('*.gif')\n"
"['1.gif', 'card.gif']\n"
">>> glob.glob('?.gif')\n"
"['1.gif']\n"
">>> glob.glob('**/*.txt', recursive=True)\n"
"['2.txt', 'sub/3.txt']\n"
">>> glob.glob('./**/', recursive=True)\n"
"['./', './sub/']"
msgstr ""
">>> nhập khẩu toàn cầu\n"
">>> glob.glob('./[0-9].*')\n"
"['./1.gif', './2.txt']\n"
">>> glob.glob('*.gif')\n"
"['1.gif', 'card.gif']\n"
">>> glob.glob('?.gif')\n"
"['1.gif']\n"
">>> glob.glob('**/*.txt', recursive=True)\n"
"['2.txt', 'sub/3.txt']\n"
">>> glob.glob('./**/', recursive=True)\n"
"['./', './sub/']"

