#: ../../library/curses.ascii.rst:194
#, fuzzy
msgid "Return the ASCII value corresponding to the low 7 bits of *c*."
msgstr "Trả về giá trị ASCII tương ứng với 7 bit thấp của *c*."

#: ../../library/curses.ascii.rst:199
#, fuzzy
msgid ""
"Return the control character corresponding to the given character (the "
"character bit value is bitwise-anded with 0x1f)."
msgstr ""
"Trả về ký tự điều khiển tương ứng với ký tự đã cho (giá trị bit ký tự được "
"tính theo bit và có 0x1f)."

#: ../../library/curses.ascii.rst:205
#, fuzzy
msgid ""
"Return the 8-bit character corresponding to the given ASCII character (the "
"character bit value is bitwise-ored with 0x80)."
msgstr ""
"Trả về ký tự 8 bit tương ứng với ký tự ASCII đã cho (giá trị bit ký tự được "
