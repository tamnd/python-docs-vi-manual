#: ../../library/tkinter.rst:1012
#, fuzzy
msgid ""
"import tkinter\n"
"widget = tkinter.Tk()\n"
"mask = tkinter.READABLE | tkinter.WRITABLE\n"
"widget.tk.createfilehandler(file, mask, callback)\n"
"...\n"
"widget.tk.deletefilehandler(file)"
msgstr ""
"nhập khẩu tkinter\n"
"tiện ích = tkinter.Tk()\n"
"mặt nạ = tkinter.READABLE | tkinter.WRITABLE\n"
