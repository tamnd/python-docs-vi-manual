#: ../../library/imaplib.rst:361
#, python-brace-format, fuzzy
msgid ""
">>> with M.idle() as idler:\n"
"...     # get a response and any others following by < 0.1 seconds\n"
"...     batch = list(idler.burst())\n"
"...     print(f'processing {len(batch)} responses...')\n"
"...     print(batch)\n"
"...\n"
"processing 3 responses...\n"
"[('EXPUNGE', [b'2']), ('EXPUNGE', [b'1']), ('RECENT', [b'0'])]"
msgstr ""
">>> với M.idle() là người chạy không tải:\n"
"... # get một phản hồi và bất kỳ phản hồi nào khác theo sau < 0,1 giây\n"
"... đợt = danh sách(idler.burst())\n"
"... print(f'processing {len(batch)} phản hồi...')\n"
"... in(đợt)\n"
"...\n"
"đang xử lý 3 phản hồi...\n"
