"boxes = {name: mailbox.mbox('~/email/%s' % name) for name in list_names}\n"
"inbox = mailbox.Maildir('~/Maildir', factory=None)\n"
"\n"
"for key in inbox.iterkeys():\n"
"    try:\n"
"        message = inbox[key]\n"
