#: ../../library/secrets.rst:152
#, fuzzy
msgid "Generate an eight-character alphanumeric password:"
msgstr "Tạo mật khẩu gồm tám ký tự chữ và số:"

#: ../../library/secrets.rst:154
#, fuzzy
msgid ""
"import string\n"
"import secrets\n"
"alphabet = string.ascii_letters + string.digits\n"
"password = ''.join(secrets.choice(alphabet) for i in range(8))"
msgstr ""
"nhập chuỗi\n"
"nhập khẩu bí mật\n"
"bảng chữ cái = string.ascii_letters + string.digits\n"
"mật khẩu = ''.join(secrets.choice(bảng chữ cái) cho tôi trong phạm vi (8))"

#: ../../library/secrets.rst:164
#, fuzzy
msgid ""
"Applications should not :cwe:`store passwords in a recoverable format "
"<257>`, whether plain text or encrypted.  They should be salted and hashed "
"using a cryptographically strong one-way (irreversible) hash function."
msgstr ""
"Các ứng dụng không nên :cwe:`store passwords in a recoverable format <257>`,"
" dù là văn bản thuần túy hay được mã hóa.  Chúng phải được muối và băm bằng "
"cách sử dụng hàm băm một chiều (không thể đảo ngược) mạnh về mặt mật mã."

#: ../../library/secrets.rst:170
#, fuzzy
msgid ""
"Generate a ten-character alphanumeric password with at least one lowercase "
"character, at least one uppercase character, and at least three digits:"
msgstr ""
"Tạo mật khẩu gồm mười ký tự chữ và số có ít nhất một ký tự chữ thường, ít "
"nhất một ký tự viết hoa và ít nhất ba chữ số:"

#: ../../library/secrets.rst:174
#, fuzzy
msgid ""
"import string\n"
"import secrets\n"
"alphabet = string.ascii_letters + string.digits\n"
"while True:\n"
"    password = ''.join(secrets.choice(alphabet) for i in range(10))\n"
"    if (any(c.islower() for c in password)\n"
"            and any(c.isupper() for c in password)\n"
"            and sum(c.isdigit() for c in password) >= 3):\n"
"        break"
msgstr ""
"nhập chuỗi\n"
"nhập khẩu bí mật\n"
"bảng chữ cái = string.ascii_letters + string.digits\n"
"trong khi Đúng:\n"
"    mật khẩu = ''.join(secrets.choice(alphabet) cho i trong phạm vi (10))\n"
"    if (any(c.islow() cho c trong mật khẩu)\n"
"            và bất kỳ(c.isupper() cho c trong mật khẩu)\n"
"            và sum(c.isdigit() cho c trong mật khẩu) >= 3):\n"
"        phá vỡ"

#: ../../library/secrets.rst:187
