#: ../../library/zoneinfo.rst:79
#, fuzzy
msgid ""
">>> LOS_ANGELES = ZoneInfo(\"America/Los_Angeles\")\n"
">>> when_utc = dt.datetime(2020, 11, 1, 8, tzinfo=dt.timezone.utc)\n"
