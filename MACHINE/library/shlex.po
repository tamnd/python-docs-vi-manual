">>> text = \"a && b; c && d || e; f >'abc'; (def \\\"ghi\\\")\"\n"
">>> s = shlex.shlex(văn bản, posix=True)\n"
">>> s.whitespace_split = Đúng\n"
">>> danh sách\n"
"['a', '&&', 'b;', 'c', '&&', 'd', '||', 'e;', 'f', '>abc;', '(def', 'ghi)']\n"
">>> s = shlex.shlex(văn bản, posix=True, punctuation_chars=True)\n"
">>> s.whitespace_split = Đúng\n"
">>> danh sách\n"
