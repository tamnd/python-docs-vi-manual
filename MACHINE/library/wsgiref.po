#: ../../library/wsgiref.rst:127
#, fuzzy
msgid ""
"Example usage (see also :func:`~wsgiref.simple_server.demo_app` for another "
"example)::"
msgstr ""
"Cách sử dụng ví dụ (xem thêm :func:`~wsgiref.simple_server.demo_app` để biết"
