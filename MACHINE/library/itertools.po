#: ../../library/itertools.rst:102
#, fuzzy
msgid ""
"def accumulate(iterable, function=operator.add, *, initial=None):\n"
"    'Return running totals'\n"
"    # accumulate([1,2,3,4,5]) → 1 3 6 10 15\n"
"    # accumulate([1,2,3,4,5], initial=100) → 100 101 103 106 110 115\n"
"    # accumulate([1,2,3,4,5], operator.mul) → 1 2 6 24 120\n"
"\n"
"    iterator = iter(iterable)\n"
"    total = initial\n"
"    if initial is None:\n"
"        try:\n"
"            total = next(iterator)\n"
"        except StopIteration:\n"
"            return\n"
"\n"
"    yield total\n"
"    for element in iterator:\n"
"        total = function(total, element)\n"
"        yield total"
msgstr ""
"def tích lũy(iterable, function=operator.add, *,init=None):\n"
"    'Trả về tổng số đang chạy'\n"
"    # accumulate([1,2,3,4,5]) → 1 3 6 10 15\n"
"    # accumulate([1,2,3,4,5], ban đầu=100) → 100 101 103 106 110 115\n"
"    # accumulate([1,2,3,4,5], operator.mul) → 1 2 6 24 120\n"
"\n"
"    iterator = iter(có thể lặp lại)\n"
"    tổng = ban đầu\n"
"    nếu ban đầu là Không có:\n"
"        thử:\n"
"            tổng = tiếp theo(iterator)\n"
"        ngoại trừ StopIteration:\n"
"            trở về\n"
"\n"
"    tổng sản lượng\n"
"    cho phần tử trong iterator:\n"
"        tổng = hàm(tổng, phần tử)\n"
"        tổng sản lượng"

#: ../../library/itertools.rst:121
#, fuzzy
msgid ""
"To compute a running minimum, set *function* to :func:`min`. For a running "
"maximum, set *function* to :func:`max`. Or for a running product, set "
"*function* to :func:`operator.mul`. To build an `amortization table "
"<https://www.ramseysolutions.com/real-estate/amortization-schedule>`_, "
"accumulate the interest and apply payments:"
msgstr ""
"Để tính mức chạy tối thiểu, đặt *function* thành :func:`min`. Để đạt mức tối"
" đa, hãy đặt *function* thành :func:`max`. Hoặc đối với sản phẩm đang chạy, "
"đặt *function* thành :func:`operator.mul`. Để xây dựng `amortization table "
"<https://www.ramseysolutions.com/real-estate/amortization-schedule>`_, hãy "
"tích lũy tiền lãi và áp dụng các khoản thanh toán:"

#: ../../library/itertools.rst:128
#, python-format, fuzzy
msgid ""
">>> data = [3, 4, 6, 2, 1, 9, 0, 7, 5, 8]\n"
">>> list(accumulate(data, max))              # running maximum\n"
"[3, 4, 6, 6, 6, 9, 9, 9, 9, 9]\n"
">>> list(accumulate(data, operator.mul))     # running product\n"
"[3, 12, 72, 144, 144, 1296, 0, 0, 0, 0]\n"
"\n"
"# Amortize a 5% loan of 1000 with 10 annual payments of 90\n"
">>> update = lambda balance, payment: round(balance * 1.05) - payment\n"
">>> list(accumulate(repeat(90, 10), update, initial=1_000))\n"
"[1000, 960, 918, 874, 828, 779, 728, 674, 618, 559, 497]"
msgstr ""
">>> dữ liệu = [3, 4, 6, 2, 1, 9, 0, 7, 5, 8]\n"
">>> danh sách (tích lũy (dữ liệu, tối đa)) # running tối đa\n"
"[3, 4, 6, 6, 6, 9, 9, 9, 9, 9]\n"
">>> danh sách(tích lũy(dữ liệu, operator.mul)) sản phẩm # running\n"
"[3, 12, 72, 144, 144, 1296, 0, 0, 0, 0]\n"
"\n"
"# Amortize khoản vay 5% trị giá 1000 với 10 khoản thanh toán hàng năm là 90\n"
