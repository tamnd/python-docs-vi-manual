#, fuzzy
msgid ""
"parser = argparse.ArgumentParser(\n"
"                    prog='ProgramName',\n"
"                    description='What the program does',\n"
"                    epilog='Text at the bottom of help')"
msgstr ""
"trình phân tích cú pháp = argparse.ArgumentParser(\n"
