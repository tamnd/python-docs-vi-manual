"            tiếp tục\n"
"        loại elif == 'SKIP':\n"
"            tiếp tục\n"
"        loại Elif == 'MISMATCH':\n"
"            raise RuntimeError(f'{value!r} không mong muốn trên dòng {line_num}')\n"
"        Mã thông báo năng suất (loại, giá trị, dòng_num, cột)\n"
"\n"
"câu lệnh = '''\n"
"    NẾU số lượng THEN\n"
