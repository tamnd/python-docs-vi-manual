"    đang chờ asyncio.sleep(delay)\n"
"    in (cái gì)\n"
"\n"
"async def main():\n"
"    print(f\"bắt đầu lúc {time.strftime('%X')}\")\n"
"\n"
"    đang chờ say_after(1, 'xin chào')\n"
"    đang chờ say_after(2, 'thế giới')\n"
"\n"
"    print(f\"hoàn thành lúc {time.strftime('%X')}\")\n"
"\n"
"asyncio.run(chính())"

