#: ../../library/getopt.rst:173
#, fuzzy
msgid "In a script, typical usage is something like this:"
msgstr "Trong một tập lệnh, cách sử dụng thông thường là như thế này:"

#: ../../library/getopt.rst:175
#, fuzzy
msgid ""
"import getopt, sys\n"
"\n"
"def main():\n"
"    try:\n"
"        opts, args = getopt.getopt(sys.argv[1:], \"ho:v\", [\"help\", \"output=\"])\n"
"    except getopt.GetoptError as err:\n"
"        # print help information and exit:\n"
"        print(err)  # will print something like \"option -a not recognized\"\n"
"        usage()\n"
"        sys.exit(2)\n"
"    output = None\n"
"    verbose = False\n"
"    for o, a in opts:\n"
"        if o == \"-v\":\n"
"            verbose = True\n"
"        elif o in (\"-h\", \"--help\"):\n"
"            usage()\n"
"            sys.exit()\n"
"        elif o in (\"-o\", \"--output\"):\n"
"            output = a\n"
"        else:\n"
"            assert False, \"unhandled option\"\n"
"    process(args, output=output, verbose=verbose)\n"
"\n"
"if __name__ == \"__main__\":\n"
"    main()"
msgstr ""
"nhập getopt, sys\n"
"\n"
"chắc chắn chính():\n"
"    thử:\n"
"        opts, args = getopt.getopt(sys.argv[1:], \"ho:v\", [\"help\", \"output=\"])\n"
"    ngoại trừ getopt.GetoptError là lỗi:\n"
"        thông tin trợ giúp # print và thoát:\n"
"        print(err) # will in một cái gì đó như \"tùy chọn -a không được nhận dạng\"\n"
"        cách sử dụng()\n"
"        sys.exit(2)\n"
"    đầu ra = Không có\n"
"    dài dòng = Sai\n"
"    cho o, a trong opts:\n"
"        nếu o == \"-v\":\n"
"            dài dòng = Đúng\n"
"        Elif o in (\"-h\", \"--help\"):\n"
"            cách sử dụng()\n"
"            sys.exit()\n"
"        elif o in (\"-o\", \"--output\"):\n"
"            đầu ra = một\n"
