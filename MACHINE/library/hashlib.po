">>> nhập hashlib\n"
">>> m = hashlib.sha256()\n"
">>> m.update(b\"Không ai kiểm tra\")\n"
">>> m.update(b\" sự lặp lại spam\")\n"
">>> m.digest()\n"
"b'\\x03\\x1e\\xdd}Ae\\x15\\x93\\xc5\\xfe\\\\\\x00o\\xa5u+7\\xfd\\xdf\\xf7\\xbcN\\x84:\\xa6\\xaf\\x0c\\x95\\x0fK\\x94\\x06'\n"
