"        khác:\n"
"            # PickleBuffer bị cấm với các giao thức dưa chua <= 4.\n"
"            kiểu trả về(self)._reconstruct, (bytearray(self),)\n"
"\n"
"    @classmethod\n"
"    def _reconstruct(cls, obj):\n"
