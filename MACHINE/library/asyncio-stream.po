"\n"
"    # Ignore thân máy, đóng ổ cắm lại\n"
"    nhà văn.close()\n"
"    đang chờ nhà văn.wait_closed()\n"
"\n"
"url = sys.argv[1]\n"
"asyncio.run(print_http_headers(url))"

